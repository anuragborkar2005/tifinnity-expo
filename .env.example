# Tifinnity Client Environment Variables Example
# Duplicate this file to .env and configure the keys. Do NOT commit the actual .env file.

# Supabase URL (e.g. https://xxxxxx.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url

# Supabase Anon Key (never use the service_role key in the Expo application)
EXPO_PUBLIC_SUPABASE_KEY=your-supabase-anon-key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
